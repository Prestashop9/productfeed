{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="productfeed-admin">
    <div class="card mb-3">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h3 class="card-header-title mb-0">
                    <i class="material-icons">rss_feed</i>
                    Product Feed Manager
                </h3>
                <a href="{{ feed_url }}" target="_blank" class="btn btn-outline-primary btn-sm">
                    <i class="material-icons">visibility</i> View Feed
                </a>
            </div>
            <ul class="nav nav-tabs card-header-tabs">
                <li class="nav-item">
                    <a class="nav-link active" href="{{ path('admin_productfeed_list') }}">
                        <i class="material-icons">list</i> Products
                        <span class="badge badge-secondary ml-1">{{ total_products }}</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ settings_url }}">
                        <i class="material-icons">settings</i> Settings
                    </a>
                </li>
            </ul>
        </div>
        <div class="card-body">
            <form method="get" action="{{ path('admin_productfeed_list') }}" class="mb-3">
                <div class="input-group" style="max-width: 400px;">
                    <input type="text" name="search" class="form-control" placeholder="Search by name or reference..." value="{{ search }}">
                    <div class="input-group-append">
                        <button type="submit" class="btn btn-primary">
                            <i class="material-icons">search</i>
                        </button>
                        {% if search %}
                        <a href="{{ path('admin_productfeed_list') }}" class="btn btn-outline-secondary">
                            <i class="material-icons">clear</i>
                        </a>
                        {% endif %}
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover" id="productfeed-table">
                    <thead class="thead-default">
                        <tr>
                            <th style="width:50px">ID</th>
                            <th style="width:60px">Image</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in products %}
                        <tr data-id="{{ product.id_product }}">
                            <td>{{ product.id_product }}</td>
                            <td>
                                {% if product.image_url %}
                                    <img src="{{ product.image_url }}" alt="" style="width:45px;height:45px;object-fit:cover;border-radius:4px;">
                                {% else %}
                                    <span class="text-muted"><i class="material-icons">image</i></span>
                                {% endif %}
                            </td>
                            <td><strong>{{ product.product_name }}</strong></td>
                            <td>{{ product.category_name }}</td>
                            <td>{{ product.formatted_price }}</td>
                            <td><small class="text-muted">{{ product.product_date_add|date('Y-m-d') }}</small></td>
                            <td><small class="text-muted">{{ product.product_date_upd|date('Y-m-d') }}</small></td>
                            <td class="text-center">
                                <div class="pf-actions-group">
                                    <button class="btn btn-sm pf-toggle-btn {{ product.is_active ? 'btn-success' : 'btn-outline-secondary' }}"
                                            data-field="is_active"
                                            data-id="{{ product.id_product }}"
                                            title="{{ product.is_active ? 'Active' : 'Hidden' }}">
                                        <i class="material-icons">{{ product.is_active ? 'visibility' : 'visibility_off' }}</i>
                                    </button>
                                    <button class="btn btn-sm pf-toggle-btn {{ product.is_sticky ? 'btn-warning' : 'btn-outline-secondary' }}"
                                            data-field="is_sticky"
                                            data-id="{{ product.id_product }}"
                                            title="{{ product.is_sticky ? 'Pinned' : 'Not pinned' }}">
                                        <i class="material-icons">{{ product.is_sticky ? 'push_pin' : 'outlined_flag' }}</i>
                                    </button>
                                    <div class="pf-badge-wrap">
                                        <button class="btn btn-sm pf-toggle-btn pf-badge-trigger {{ product.badge_text ? 'btn-info' : 'btn-outline-secondary' }}"
                                                data-id="{{ product.id_product }}"
                                                data-badge-text="{{ product.badge_text|default('')|e('html_attr') }}"
                                                data-badge-expires="{{ product.badge_expires ? product.badge_expires|date('Y-m-d') : '' }}"
                                                title="{{ product.badge_text ? product.badge_text : 'No badge' }}">
                                            <i class="material-icons">{{ product.badge_text ? 'label' : 'label_off' }}</i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No products found.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if total_pages > 1 %}
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    {% if current_page > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('admin_productfeed_list', {page: current_page - 1, search: search}) }}">
                            <i class="material-icons">chevron_left</i>
                        </a>
                    </li>
                    {% endif %}

                    {% for p in range(max(1, current_page - 3), min(total_pages, current_page + 3)) %}
                    <li class="page-item {{ p == current_page ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('admin_productfeed_list', {page: p, search: search}) }}">{{ p }}</a>
                    </li>
                    {% endfor %}

                    {% if current_page < total_pages %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('admin_productfeed_list', {page: current_page + 1, search: search}) }}">
                            <i class="material-icons">chevron_right</i>
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </nav>
            {% endif %}
        </div>
    </div>
</div>

{# Badge popup (single instance, repositioned on click) #}
<div class="pf-badge-popup" id="pf-badge-popup" style="display:none;">
    <div class="pf-badge-popup__header">
        <strong>Set Badge</strong>
        <button type="button" class="pf-badge-popup__close" id="pf-badge-close">&times;</button>
    </div>
    <div class="pf-badge-popup__presets">
        <button type="button" class="pf-badge-preset" data-text="New Content">New Content</button>
        <button type="button" class="pf-badge-preset" data-text="New">New</button>
        <button type="button" class="pf-badge-preset" data-text="Hot">Hot</button>
        <button type="button" class="pf-badge-preset" data-text="Sale">Sale</button>
        <button type="button" class="pf-badge-preset" data-text="Discount">Discount</button>
        <button type="button" class="pf-badge-preset" data-text="Limited">Limited</button>
        <button type="button" class="pf-badge-preset" data-text="Trending">Trending</button>
    </div>
    <div class="pf-badge-popup__form">
        <input type="text" id="pf-badge-text" class="form-control form-control-sm" placeholder="Custom text..." maxlength="50">
        <div class="pf-badge-popup__expiry">
            <label><small>Expires</small></label>
            <div class="d-flex align-items-center gap-2">
                <input type="date" id="pf-badge-expires" class="form-control form-control-sm">
                <label class="pf-badge-lifetime mb-0">
                    <input type="checkbox" id="pf-badge-lifetime"> <small>Lifetime</small>
                </label>
            </div>
        </div>
        <div class="pf-badge-popup__actions">
            <button type="button" class="btn btn-sm btn-primary" id="pf-badge-save">Apply</button>
            <button type="button" class="btn btn-sm btn-outline-danger" id="pf-badge-remove">Remove</button>
        </div>
    </div>
</div>

<style>
.productfeed-admin .table td { vertical-align: middle; }
.pf-actions-group { display: inline-flex; gap: 4px; align-items: center; }
.pf-toggle-btn { width: 34px; height: 34px; padding: 4px; border-radius: 50%; transition: all 0.2s ease; }
.pf-toggle-btn:hover { transform: scale(1.1); }
.pf-toggle-btn .material-icons { font-size: 18px; }
.pf-badge-wrap { position: relative; }

/* Badge popup */
.pf-badge-popup {
    position: fixed;
    z-index: 10000;
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 10px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    width: 280px;
    padding: 0;
    overflow: hidden;
}
.pf-badge-popup__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid #f0f0f0;
    background: #f8f9fa;
}
.pf-badge-popup__close {
    border: none; background: none; font-size: 20px; cursor: pointer; color: #999; line-height: 1;
}
.pf-badge-popup__presets {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 12px 14px 8px;
}
.pf-badge-preset {
    padding: 4px 12px;
    border: 1px solid #dee2e6;
    border-radius: 20px;
    background: #fff;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
}
.pf-badge-preset:hover, .pf-badge-preset.active {
    background: #25b9d7;
    color: #fff;
    border-color: #25b9d7;
}
.pf-badge-popup__form {
    padding: 8px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.pf-badge-popup__expiry label { margin-bottom: 2px; color: #666; }
.pf-badge-popup__expiry .gap-2 { gap: 8px; }
.pf-badge-lifetime { white-space: nowrap; cursor: pointer; }
.pf-badge-popup__actions { display: flex; gap: 8px; margin-top: 4px; }
.pf-badge-popup__actions .btn { flex: 1; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var toggleUrl = '{{ toggle_url }}';
    var badgeUrl = '{{ badge_url }}';
    var popup = document.getElementById('pf-badge-popup');
    var badgeText = document.getElementById('pf-badge-text');
    var badgeExpires = document.getElementById('pf-badge-expires');
    var badgeLifetime = document.getElementById('pf-badge-lifetime');
    var currentBadgeTrigger = null;

    // Toggle buttons (active / sticky)
    document.querySelectorAll('.pf-toggle-btn:not(.pf-badge-trigger)').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var button = this;
            button.disabled = true;
            fetch(toggleUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: 'id_product=' + button.dataset.id + '&field=' + button.dataset.field
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    var isOn = data.new_value === 1;
                    var f = button.dataset.field;
                    if (f === 'is_active') {
                        button.className = 'btn btn-sm pf-toggle-btn ' + (isOn ? 'btn-success' : 'btn-outline-secondary');
                        button.innerHTML = '<i class="material-icons">' + (isOn ? 'visibility' : 'visibility_off') + '</i>';
                        button.title = isOn ? 'Active' : 'Hidden';
                    } else if (f === 'is_sticky') {
                        button.className = 'btn btn-sm pf-toggle-btn ' + (isOn ? 'btn-warning' : 'btn-outline-secondary');
                        button.innerHTML = '<i class="material-icons">' + (isOn ? 'push_pin' : 'outlined_flag') + '</i>';
                        button.title = isOn ? 'Pinned' : 'Not pinned';
                    }
                }
                button.disabled = false;
            })
            .catch(function() { button.disabled = false; });
        });
    });

    // Badge popup — open
    document.querySelectorAll('.pf-badge-trigger').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            currentBadgeTrigger = this;
            var rect = this.getBoundingClientRect();
            popup.style.top = (rect.bottom + 6) + 'px';
            popup.style.left = Math.min(rect.left, window.innerWidth - 300) + 'px';
            popup.style.display = 'block';

            badgeText.value = this.dataset.badgeText || '';
            badgeExpires.value = this.dataset.badgeExpires || '';
            badgeLifetime.checked = !this.dataset.badgeExpires && !!this.dataset.badgeText;
            badgeExpires.disabled = badgeLifetime.checked;

            // Highlight matching preset
            document.querySelectorAll('.pf-badge-preset').forEach(function(p) {
                p.classList.toggle('active', p.dataset.text === badgeText.value);
            });
        });
    });

    // Badge popup — close
    document.getElementById('pf-badge-close').addEventListener('click', function() { popup.style.display = 'none'; });
    document.addEventListener('click', function(e) {
        if (!popup.contains(e.target) && !e.target.closest('.pf-badge-trigger')) popup.style.display = 'none';
    });

    // Presets
    document.querySelectorAll('.pf-badge-preset').forEach(function(btn) {
        btn.addEventListener('click', function() {
            badgeText.value = this.dataset.text;
            document.querySelectorAll('.pf-badge-preset').forEach(function(p) { p.classList.remove('active'); });
            this.classList.add('active');
        });
    });

    // Lifetime checkbox
    badgeLifetime.addEventListener('change', function() {
        badgeExpires.disabled = this.checked;
        if (this.checked) badgeExpires.value = '';
    });

    // Save badge
    document.getElementById('pf-badge-save').addEventListener('click', function() {
        if (!currentBadgeTrigger || !badgeText.value.trim()) return;
        var id = currentBadgeTrigger.dataset.id;
        var body = 'id_product=' + id + '&badge_action=set&badge_text=' + encodeURIComponent(badgeText.value.trim());
        if (badgeExpires.value) body += '&badge_expires=' + badgeExpires.value;

        fetch(badgeUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: body
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                currentBadgeTrigger.dataset.badgeText = data.badge_text;
                currentBadgeTrigger.dataset.badgeExpires = data.badge_expires;
                currentBadgeTrigger.className = 'btn btn-sm pf-toggle-btn pf-badge-trigger btn-info';
                currentBadgeTrigger.innerHTML = '<i class="material-icons">label</i>';
                currentBadgeTrigger.title = data.badge_text;
                popup.style.display = 'none';
            }
        });
    });

    // Remove badge
    document.getElementById('pf-badge-remove').addEventListener('click', function() {
        if (!currentBadgeTrigger) return;
        var id = currentBadgeTrigger.dataset.id;

        fetch(badgeUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: 'id_product=' + id + '&badge_action=remove'
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                currentBadgeTrigger.dataset.badgeText = '';
                currentBadgeTrigger.dataset.badgeExpires = '';
                currentBadgeTrigger.className = 'btn btn-sm pf-toggle-btn pf-badge-trigger btn-outline-secondary';
                currentBadgeTrigger.innerHTML = '<i class="material-icons">label_off</i>';
                currentBadgeTrigger.title = 'No badge';
                popup.style.display = 'none';
            }
        });
    });
});
</script>
{% endblock %}
